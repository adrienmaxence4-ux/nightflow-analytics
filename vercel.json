{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["cdg1"],
  "crons": [
    { "path": "/api/integrations/sync", "schedule": "0 * * * *" },
    { "path": "/api/integrations/jobs/process", "schedule": "*/10 * * * *" }
  ]
}
