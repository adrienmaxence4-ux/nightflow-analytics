# ───────────────────────────────────────────────────────────
# Nightflow Analytics — Environment variables
# Copy this file to `.env.local` and fill in your values.
# The app runs in DEMO MODE (mock data, fake auth) when these
# are left empty — so you can clone & run immediately.
# ───────────────────────────────────────────────────────────

# Supabase (Auth + Database) — https://app.supabase.com → Project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# AI Copilot (Phase 2) — Anthropic API key for real insights
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Future e-commerce integrations (Phase 2) ──
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# STRIPE_SECRET_KEY=
# META_ACCESS_TOKEN=
# TIKTOK_ACCESS_TOKEN=
# KLAVIYO_API_KEY=

# Public site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
