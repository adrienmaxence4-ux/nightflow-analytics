# ───────────────────────────────────────────────────────────
# Nightflow Analytics — Environment variables
# Copy this file to `.env.local` and fill in your values.
# The app runs in DEMO MODE (mock data, fake auth) when these
# are left empty — so you can clone & run immediately.
# ───────────────────────────────────────────────────────────

# Supabase (Auth + Database) — https://app.supabase.com → Project settings → API
# The app uses ONLY the public anon key + Row-Level Security (no service-role
# key on the server), so every query is scoped to the logged-in user.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL (used for auth + OAuth redirects). In Vercel set this to your
# production domain, e.g. https://nightflow-analytics.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin allowlist (comma-separated emails). These users can use the demo/test
# data tools, which are hidden from real customers. Leave empty in production to
# lock the tools down entirely.
ADMIN_EMAILS=

# ── AI Copilot ──────────────────────────────────────────────
# Choose the provider: "github" (free, for testing) | "anthropic" (paid) | "auto"
AI_PROVIDER=auto

# Option 1 — GitHub Models (FREE, ideal for test mode)
# Create a fine-grained PAT with the "Models" (read) permission:
# https://github.com/settings/personal-access-tokens  →  set AI_PROVIDER=github
GITHUB_MODELS_TOKEN=
GITHUB_MODEL=openai/gpt-4o-mini
# GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# Option 2 — Anthropic Claude (paid, for production)
# Get a key at https://console.anthropic.com  →  set AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional: override the model (default: claude-opus-4-8). e.g. claude-sonnet-4-6
AI_MODEL=

# ── Shopify (OAuth — Dev Dashboard app) ──
# App URL      = <NEXT_PUBLIC_SITE_URL>/api/integrations/shopify
# Redirect URL = <NEXT_PUBLIC_SITE_URL>/api/integrations/shopify/callback
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# SHOPIFY_SCOPES=read_products,read_orders,read_customers,read_inventory

# ── Stripe ──
# Used for BOTH "Connect with Stripe" (one-click data import) and subscription
# billing (Checkout / Customer Portal / plan changes).
#   STRIPE_SECRET_KEY        = platform secret key (sk_live_… / sk_test_…)
#   STRIPE_CONNECT_CLIENT_ID = Connect client id (ca_…), Standard OAuth enabled
# Redirect URL = <NEXT_PUBLIC_SITE_URL>/api/integrations/stripe/oauth/callback
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=

# ── Klaviyo (OAuth 2.0 + PKCE) ──
# Redirect URL = <NEXT_PUBLIC_SITE_URL>/api/integrations/klaviyo/oauth/callback
KLAVIYO_CLIENT_ID=
KLAVIYO_CLIENT_SECRET=

# ── Google (OAuth → Google Analytics GA4) ──
# Redirect URL = <NEXT_PUBLIC_SITE_URL>/api/integrations/google/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
